# ===== Banco de Dados (MySQL) =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_do_banco_aqui
DB_NAME=moneyhub

# ===== Ambiente =====
ENVIRONMENT=development
DEBUG=true
DEBUG_ROUTES_ENABLED=true

# ===== JWT / Autenticação =====
# Gere segredos fortes com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=gere_um_segredo_forte_aqui
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_SECRET=gere_outro_segredo_forte_aqui
JWT_REFRESH_EXPIRATION_DAYS=7

# ===== Cookies / CSRF =====
SECURITY_COOKIES_ENABLED=true
REFRESH_FROM_COOKIE=true
CSRF_ENFORCE=true
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=http://localhost:3000,http://127.0.0.1:3000

# ===== CORS / Hosts Permitidos =====
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1

# ===== Google OAuth =====
# Obtenha em https://console.cloud.google.com/ (APIs & Services > Credentials)
GOOGLE_CLIENT_ID=seu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_google_client_secret_aqui
SESSION_SECRET_KEY=gere_um_segredo_forte_aqui
FRONTEND_URL=http://localhost:3000

# ===== SMTP (envio de e-mail) =====
# Exemplo com Brevo (antigo Sendinblue). Ajuste para seu provedor.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=seu_smtp_username_aqui
SMTP_PASSWORD=sua_smtp_password_aqui
SMTP_FROM_EMAIL=seu_email@exemplo.com
SMTP_FROM_NAME=MoneyHub
EMAIL_VERIFICATION_EXPIRY_MINUTES=15
